{
  "name": "specdrive-vscode",
  "version": "1.0.0",
  "description": "SpecDrive Core Engine (Parser and State Machine) in VSCode",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onCommand:specdrive.run"
  ],
  "contributes": {
    "commands": [
      {
        "command": "specdrive.run",
        "title": "SpecDrive: Run Tasks"
      }
    ]
  },
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.118.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
